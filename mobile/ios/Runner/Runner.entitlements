<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- APNs (push). `development` here; a release build uses `production`.
	     Wiring this file into the target (CODE_SIGN_ENTITLEMENTS) + adding the
	     Push Notifications capability is an Xcode step — see
	     docs/DEPLOYMENT.md §B4 (it needs the Apple developer account). -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
