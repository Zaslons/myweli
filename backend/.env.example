# Copy to `.env` for local dev and fill in. NEVER commit a real `.env`
# (it is gitignored; CI secret-scans the repo). Production supplies these via
# the platform's secret manager, not a file.

# Runtime environment: dev | staging | prod.
# Dev/staging return the OTP inline (devCode); prod never does.
ENV=dev

# HS256 signing key for access-token JWTs. Generate a long random value, e.g.:
#   dart -e "import 'dart:math'; import 'dart:convert'; void main(){final r=Random.secure(); print(base64Url.encode(List<int>.generate(48,(_)=>r.nextInt(256))));}"
JWT_SECRET=replace-with-a-long-random-secret

# Seed super-admin for the internal admin console (docs/design/admin-console.md).
# On first boot an admin with this email is created if absent (idempotent; the
# password is bcrypt-hashed). Leave unset to skip seeding. No admin self-signup.
# ADMIN_EMAIL=ops@myweli.ci
# ADMIN_PASSWORD=replace-with-a-strong-password

# Postgres connection. When set, the backend uses Postgres-backed repositories;
# unset → in-memory (fine for dev / CI-without-DB). Uncomment + fill to enable.
# DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/myweli

# Object storage for image uploads (Cloudflare R2; S3-compatible). When all are
# set, POST /uploads/sign issues real presigned uploads; unset → a no-network
# Fake (dev/CI). REQUIRED in production. The keys are secrets — never commit a
# real .env. Design: docs/design/pro-image-upload-pipeline.md.
#   R2_ENDPOINT wins if set (use it for AWS S3 / Supabase / MinIO); otherwise
#   the endpoint is derived from R2_ACCOUNT_ID.
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# R2_BUCKET=myweli-uploads
# R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
# R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
# R2_PUBLIC_BASE_URL=https://cdn.myweli.com
#   A SEPARATE, PRIVATE bucket for KYC identity documents (no public domain
#   bound to it — never web-reachable). Design: docs/design/pro-kyc.md.
# R2_KYC_BUCKET=myweli-kyc-private
#   A SEPARATE, PRIVATE bucket for deposit-payment screenshots (also never
#   web-reachable; kept apart from KYC so it can have its own retention/access).
#   Design: docs/design/consumer-deposit.md.
# R2_DEPOSIT_BUCKET=myweli-deposits-private

# Outbound messaging (WhatsApp + SMS via Twilio). When all four are set the
# backend sends via Twilio; unset → a no-network log provider (dev/CI). REQUIRED
# in production. Secrets — never commit a real .env. The `*_FROM` values are the
# Twilio sender numbers (E.164; the WhatsApp one without the `whatsapp:` prefix —
# the adapter adds it). Design: docs/design/messaging-notifications.md.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
# TWILIO_SMS_FROM=+1XXXXXXXXXX
# TWILIO_WHATSAPP_FROM=+1XXXXXXXXXX
#   Shared secret guarding the delivery-status webhook; set the Twilio status
#   callback URL to /webhooks/messaging/status?secret=THIS. Unset → webhook open
#   (dev). Design: docs/design/messaging-notifications.md §5.
# MESSAGING_WEBHOOK_SECRET=replace-with-a-long-random-secret
