{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/connexion"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*/connexion",
          "assertions": {
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:performance": [
              "warn",
              {
                "minScore": 0.8
              }
            ],
            "categories:best-practices": [
              "warn",
              {
                "minScore": 0.9
              }
            ]
          }
        },
        {
          "matchingUrlPattern": "http://127.0.0.1:3000/$",
          "assertions": {
            "categories:seo": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:performance": [
              "warn",
              {
                "minScore": 0.8
              }
            ],
            "categories:best-practices": [
              "warn",
              {
                "minScore": 0.9
              }
            ]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
